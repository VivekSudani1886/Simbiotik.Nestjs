    "rxjs": "^7.8.0",
    "swagger-ui-express": "^4.6.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^3.0.8",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
